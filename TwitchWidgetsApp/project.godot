; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TwitchWidgetsApp"
config/description="Enter an interesting project description here!"
run/main_scene="res://Scenes/ProjectionWindow.tscn"
config/features=PackedStringArray("4.2", "C#")
config/icon="res://TwitchWidgets.png"

[audio]

general/text_to_speech=true

[autoload]

Globals="*res://Library/Globals.cs"
ElgatoStreamDeck="*res://addons/godot-streamdeck-addon/singleton.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_position_type=2
window/size/initial_screen=1
window/size/transparent=true
window/size/window_width_override=1440
window/size/window_height_override=810
window/subwindows/embed_subwindows=false
window/per_pixel_transparency/allowed=true

[dotnet]

project/assembly_name="TwitchWidgetsApp"
project/solution_directory="..\\"

[editor]

naming/scene_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/fontawesome/plugin.cfg", "res://addons/godot-streamdeck-addon/plugin.cfg")

[gui]

theme/default_font_antialiasing=2
theme/default_font_hinting=0

[input]

fullscreen={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":true,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194309,"key_label":0,"unicode":0,"echo":false,"script":null)
]
}
show_settings={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":true,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":84,"key_label":0,"unicode":84,"echo":false,"script":null)
]
}

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
viewport/transparent_background=true
